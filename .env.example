# Feishu Open Platform credentials
FEISHU_APP_ID=cli_xxxxxxxxxxxxxxxx
FEISHU_APP_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Event subscription verification token (from Feishu Open Platform > Event Subscriptions)
FEISHU_VERIFICATION_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Optional: encryption key (if "Encrypt Key" is enabled on Open Platform)
# FEISHU_ENCRYPT_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# HTTP server port
PORT=3000
